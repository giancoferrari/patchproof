{
  "name": "@giancoferrari/patchproof",
  "version": "0.1.0",
  "description": "Independent, inspectable evidence for AI-written code.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "patchproof": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": "./schemas/proof-bundle.schema.json"
  },
  "files": [
    "dist",
    "schemas",
    "templates",
    "docs",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "CODE_OF_CONDUCT.md",
    "CONTRIBUTING.md",
    "ROADMAP.md",
    "SECURITY.md"
  ],
  "engines": {
    "node": ">=20.12"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "demo": "tsx scripts/generate-demo.ts",
    "demo:serve": "node scripts/serve-examples.mjs",
    "check": "npm run typecheck && npm run coverage && npm run build",
    "prepare": "npm run build",
    "prepublishOnly": "npm run check"
  },
  "keywords": [
    "ai",
    "coding-agents",
    "code-review",
    "verification",
    "attestation",
    "ci",
    "security",
    "local-first"
  ],
  "author": "Giancarlo Ferrari",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/giancoferrari/patchproof.git"
  },
  "bugs": {
    "url": "https://github.com/giancoferrari/patchproof/issues"
  },
  "homepage": "https://github.com/giancoferrari/patchproof#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "fast-glob": "^3.3.3",
    "minimatch": "^10.0.3",
    "picocolors": "^1.1.1",
    "yaml": "^2.8.1",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@types/node": "^24.1.0",
    "@vitest/coverage-v8": "^3.2.4",
    "tsup": "^8.5.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
